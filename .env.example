# Kopieer dit bestand naar .env en vul je eigen waarden in (nooit committen).
# (Of laat setup_telegram.py de Telegram-waarden automatisch invullen.)

# --- Merk (website-UI; defaults zijn al goed, overschrijven is optioneel) ---
BRAND_NAME=Vliegseintje
BRAND_TAGLINE=Goedkoop vliegen, zonder zoeken.
SOCIAL_INSTAGRAM=vliegseintje
SOCIAL_TIKTOK=vliegseintje
SOCIAL_X=vliegseintje
SUPPORT_EMAIL=                        # ontvanger contactformulier; leeg = RESEND_FROM

# --- Privacyvriendelijke analytics + foutmonitoring (opt-in; leeg = uit) ---
PLAUSIBLE_DOMAIN=                      # bv. vliegseintje.nl; script wordt alleen geladen als gezet
SENTRY_DSN=

# --- Database ---
# Lokaal/Docker: matcht docker-compose.yml. In productie (Hetzner) eigen waarden.
DATABASE_URL=postgresql+psycopg://ryanair:ryanair@localhost:5433/ryanair

# --- Telegram (bestaand kanaal) ---
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIjKlMnOpQrStUvWxYz
TELEGRAM_CHAT_ID=123456789
TELEGRAM_BOT_USERNAME=goedkoopvliegen_bot

# --- E-mail (transactionele API: Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=deals@jouwdomein.nl
APP_BASE_URL=https://jouwdomein.nl

# --- Providers (CSV) ---
ENABLED_PROVIDERS=ryanair

# --- Travelpayouts (databron + affiliate; cached Data API — zie DECISIONS D8) ---
# Gratis self-serve: registreer op travelpayouts.com -> Profiel -> API token + Partner-marker.
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=
TRAVELPAYOUTS_MARKET=nl

# --- Scan-instellingen ---
CURRENCY=EUR
CONCURRENCY=8

# --- Standaard-voorkeuren voor nieuwe gebruikers ---
DEFAULT_THRESHOLD=50.0
DEFAULT_MONTHS_AHEAD=3
DEFAULT_TRIP_LENGTHS=3,5,7

# --- Premium / gating (Fase 2) ---
PREMIUM_ONLY_FEATURES=mode:instant,channel:whatsapp
FREE_MAX_ORIGINS=1

# --- Mollie-abonnement (Fase 2) ---
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxx
PREMIUM_PRICE=                       # bv. 2.99 — vul je eigen prijs in (verplicht voor checkout)
PREMIUM_CURRENCY=EUR
PREMIUM_INTERVAL=1 month
PREMIUM_DESCRIPTION=Goedkoop Vliegen Premium

# --- WhatsApp (Fase 2; uit tot je API-toegang hebt) ---
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
