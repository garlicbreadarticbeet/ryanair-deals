# Kopieer dit bestand naar .env en vul je eigen waarden in (nooit committen).
# (Of laat setup_telegram.py de Telegram-waarden automatisch invullen.)

# --- Merk (website-UI; defaults zijn al goed, overschrijven is optioneel) ---
BRAND_NAME=Vliegseintje
BRAND_TAGLINE=Goedkoop vliegen, zonder zoeken.
SOCIAL_INSTAGRAM=vliegseintje
SOCIAL_TIKTOK=vliegseintje
SOCIAL_X=vliegseintje
SUPPORT_EMAIL=                        # ontvanger contactformulier; leeg = RESEND_FROM

# --- Privacyvriendelijke analytics + foutmonitoring (opt-in; leeg = uit) ---
PLAUSIBLE_DOMAIN=                      # bv. vliegseintje.nl; script wordt alleen geladen als gezet
SENTRY_DSN=

# --- Database ---
# Lokaal/Docker: matcht docker-compose.yml. In productie (Hetzner) eigen waarden.
DATABASE_URL=postgresql+psycopg://ryanair:ryanair@localhost:5433/ryanair

# --- Telegram (bestaand kanaal) ---
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIjKlMnOpQrStUvWxYz
TELEGRAM_CHAT_ID=123456789
TELEGRAM_BOT_USERNAME=goedkoopvliegen_bot

# --- E-mail (transactionele API: Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=deals@vliegseintje.nl
APP_BASE_URL=https://vliegseintje.nl

# --- Alert-dealkaarten (gebrande PNG) ---
# Ondertekent de /cards-URL voor de hero-afbeelding in de e-mail. Leeg = geen hero-afbeelding
# (de HTML-kaarten blijven); Telegram-foto's werken sowieso. Zet een sterk willekeurig geheim,
# bv. `openssl rand -hex 32`.
ALERT_CARD_SECRET=

# --- Deploy (Caddy reverse proxy + auto-HTTPS; alleen prod-profiel) ---
# Domein waarvoor Caddy een TLS-cert haalt. Vereist DNS A-record -> VPS-IP.
SITE_DOMAIN=vliegseintje.nl

# --- Providers (CSV) ---
ENABLED_PROVIDERS=ryanair
# Databron waaraan NIEUWE vertrekvelden worden gekoppeld (bepaalt welke adapter scant):
# 'ryanair' = Ryanair's eigen cheapestPerDay → de scherpste, actuele fares (zie DECISIONS D12);
# 'travelpayouts' = gecachte Data API + affiliate (indicatief, vaak veel hoger — zie D8).
DEFAULT_ORIGIN_PROVIDER=ryanair

# --- Travelpayouts (databron + affiliate; cached Data API — zie DECISIONS D8) ---
# Gratis self-serve: registreer op travelpayouts.com -> Profiel -> API token + Partner-marker.
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=
TRAVELPAYOUTS_MARKET=nl

# --- Scan-instellingen ---
CURRENCY=EUR
CONCURRENCY=8

# --- Standaard-voorkeuren voor nieuwe gebruikers ---
DEFAULT_THRESHOLD=50.0
DEFAULT_MONTHS_AHEAD=3
DEFAULT_TRIP_LENGTHS=3,5,7

# --- Premium / gating (Fase 2) ---
PREMIUM_ONLY_FEATURES=mode:instant
FREE_MAX_ORIGINS=1

# --- Prijzen (maand + jaar; incl. btw, in EUR). Komen volledig uit config. ---
PREMIUM_PRICE_MONTHLY=2.99
PREMIUM_PRICE_ANNUAL=24.99
PREMIUM_CURRENCY=EUR
PREMIUM_DESCRIPTION=Vliegseintje Premium

# --- Betaalprovider: "lemonsqueezy" (Merchant of Record, geen KvK nodig) of "mollie" ---
BILLING_PROVIDER=lemonsqueezy

# --- Lemon Squeezy (Merchant of Record; regelt EU-btw). Variant-ID's per plan uit je dashboard. ---
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_MONTHLY=
LEMONSQUEEZY_VARIANT_ANNUAL=
LEMONSQUEEZY_WEBHOOK_SECRET=         # HMAC-secret dat je in de webhook-instellingen zet

# --- Mollie (latere optie na KvK-inschrijving; interval per plan in Mollie-formaat) ---
MOLLIE_API_KEY=                      # test_... of live_...
MOLLIE_INTERVAL_MONTHLY=1 month
MOLLIE_INTERVAL_ANNUAL=12 months
